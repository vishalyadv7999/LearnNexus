NODE_ENV=development
PORT=5001
MONGODB_URI=mongodb+srv://USERNAME:PASSWORD@CLUSTER.mongodb.net/learnnexus?retryWrites=true&w=majority
MONGO_MAX_POOL_SIZE=30
MONGO_MIN_POOL_SIZE=3
MONGO_SERVER_SELECTION_TIMEOUT_MS=10000
MONGO_CONNECT_TIMEOUT_MS=10000
MONGO_SOCKET_TIMEOUT_MS=45000
MONGO_CONNECT_RETRY_DELAY_MS=5000
MONGO_CONNECT_MAX_RETRIES=3
JWT_SECRET=replace_with_a_64_character_random_secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_DAYS=30
REFRESH_COOKIE_NAME=learnnexus_refresh
COOKIE_SECURE=true
COOKIE_SAME_SITE=lax
CLIENT_URL=https://learnnexus.example.com
SERVER_URL=https://api.learnnexus.example.com
TRUST_PROXY=true
LOG_LEVEL=info
REDIS_URL=redis://redis:6379
# Optional. Leave blank if you do not have a key; keep AUTO_RESUME_PLAYLIST_IMPORTS=false.
YOUTUBE_API_KEY=
AUTO_RESUME_PLAYLIST_IMPORTS=false
# Optional: the Learning Assistant shows a safe unavailable message when omitted.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
AI_PROVIDER=openai
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash
LEARNING_ASSISTANT_TIMEOUT_MS=30000
LEARNING_ASSISTANT_MAX_RETRIES=1
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
EMAIL_USER=yourgmail@gmail.com
EMAIL_PASS=your_16_character_gmail_app_password
EMAIL_FROM=LearnNexus <yourgmail@gmail.com>
